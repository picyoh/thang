---
import { Icon } from "astro-iconify";
import Time from "../components/Time/Time.astro";
//TODO: mobile styling (duplicate Time and display it conditionnaly with width check+)
---

<header class="relative flex justify-between item-center border">
  <div class="flex">
    <a href="/" class="text-center w-4 border">1</a>
    <a href="/gui" class="text-center w-4 border">2</a>
  </div>

  <a href="/" class="absolute w-fit m-auto left-0 right-0">
    <h1>Thang</h1>
  </a>

  <div class="flex">
    <span class="flex items-center">
      <Icon name="material-symbols:no-sound-rounded" size={18} />
    </span>
   <Time
      type="time"
      format="hh:mm:ss"
      icon="material-symbols:nest-clock-farsight-analog-outline-rounded"
      size={18}
    />
    <Time
      type="date"
      format="dd/mm/yy"
      icon="material-symbols:calendar-month-rounded"
      size={18}
    />
  </div>
</header>